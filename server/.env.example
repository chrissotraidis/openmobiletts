# Open Mobile TTS Server Configuration
# Copy to .env and customize as needed. All settings have sensible defaults.

# TTS Engine Settings
KOKORO_LANG_CODE=a
DEFAULT_VOICE=af_heart
DEFAULT_SPEED=1.0
MAX_CHUNK_TOKENS=250

# Audio Encoding Settings
MP3_BITRATE=64k
MP3_SAMPLE_RATE=22050

# Server Settings
HOST=0.0.0.0
PORT=8000
WORKERS=1

# File Upload Settings
MAX_UPLOAD_SIZE_MB=10
UPLOAD_DIR=/tmp/openmobiletts_uploads

# CORS Settings (only needed for dev mode with separate vite server)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
