# Open Mobile TTS Server Configuration
# Copy to .env and customize as needed. All settings have sensible defaults.

# TTS Engine Selection: 'kokoro' (PyTorch, default) or 'sherpa-onnx' (ONNX)
TTS_ENGINE=kokoro

# Kokoro PyTorch Settings
KOKORO_LANG_CODE=a
DEFAULT_VOICE=af_heart
DEFAULT_SPEED=1.0
MAX_CHUNK_TOKENS=250

# Sherpa-ONNX Settings (only used when TTS_ENGINE=sherpa-onnx)
# SHERPA_MODEL_DIR=~/.cache/sherpa-onnx-kokoro/kokoro-multi-lang-v1_0
# SHERPA_NUM_THREADS=2

# Audio Encoding Settings
MP3_BITRATE=64k
MP3_SAMPLE_RATE=22050

# Server Settings
HOST=0.0.0.0
PORT=8000
WORKERS=1

# File Upload Settings
MAX_UPLOAD_SIZE_MB=10
UPLOAD_DIR=/tmp/openmobiletts_uploads
